#!/bin/bash
#SBATCH --job-name=mma_eval_all
#SBATCH --output=logs/eval_all_%A_%a.out
#SBATCH --error=logs/eval_all_%A_%a.err
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=32G
#SBATCH --time=12:00:00
#SBATCH --partition=acltr
#SBATCH --gres=gpu:1
#SBATCH --mail-user=edlu@itu.dk
#SBATCH --mail-type=FAIL,ARRAY_TASKS

# Array eval: one task per directory under output/ that matches output/gw_*
# (or PATTERN). Each task does a full post-training eval (synthesize EMA +
# generate test audio + compute metrics) and writes
# output/<exp_id>/test-output_metrics.json.
#
# Submit:
#   N=$(ls -d output/gw_* 2>/dev/null | wc -l)
#   sbatch --array=0-$((N-1)) jobs/eval_all.job
#
# Or for a custom pattern:
#   PATTERN='output/gw_var_*' N=$(ls -d $PATTERN | wc -l)
#   sbatch --array=0-$((N-1)) --export=ALL,PATTERN="$PATTERN" jobs/eval_all.job
#
# Auto-skip: if test-output_metrics.json already exists for a run, the array
# task short-circuits unless FORCE=1.

set -e
set -x

# --- 1. Environment & Path Definitions ---
PROJECT_DIR="$HOME/MMA/MMAudio"
ENV_PATH="/home/edlu/miniconda3-25-5-1-1/envs/gwot"
CONDA_BIN="/opt/itu/easybuild/software/Miniconda3/25.5.1-1/bin/conda"

# --- 2. Load System Modules ---
module load CUDA/12.1.1
module load NCCL/2.18.3-GCCcore-12.3.0-CUDA-12.1.1
module load Miniconda3/25.5.1-1
source /opt/itu/easybuild/software/Miniconda3/25.5.1-1/etc/profile.d/conda.sh
conda activate "$ENV_PATH"
cd "$PROJECT_DIR"

# --- 3. Avoid `import torch` hang on shared FS ---
export TORCH_DEVICE_BACKEND_AUTOLOAD=0
echo "Pre-warming torch import cache..."
time python -c "import torch; print('torch', torch.__version__)"
echo "Cache warm."

mkdir -p logs

# --- 4. Knobs (override via --export) ---
PATTERN="${PATTERN:-output/gw_*}"
MODEL="${MODEL:-small_16k}"
DURATION="${DURATION:-8.0}"
BATCH_SIZE="${BATCH_SIZE:-4}"
EXTRACT_BS="${EXTRACT_BS:-4}"
NUM_WORKERS="${NUM_WORKERS:-4}"
FORCE="${FORCE:-0}"
COMPILE="${COMPILE:-False}"

# Reduce CUDA memory fragmentation for the inference -> extract handoff.
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# --- 5. Discover runs and pick the one for this array index ---
mapfile -t RUNS < <(ls -1d $PATTERN 2>/dev/null | xargs -n1 basename | sort)
N=${#RUNS[@]}
if [ "$N" -eq 0 ]; then
    echo "ERROR: no runs match $PATTERN — submit training jobs first"
    exit 2
fi
if [ -z "${SLURM_ARRAY_TASK_ID:-}" ]; then
    echo "ERROR: SLURM_ARRAY_TASK_ID is unset — submit with --array=0-$((N-1)) (you have $N runs)"
    exit 2
fi
if [ "$SLURM_ARRAY_TASK_ID" -ge "$N" ]; then
    echo "Array index $SLURM_ARRAY_TASK_ID >= $N runs — nothing to do."
    exit 0
fi

EXP_ID="${RUNS[$SLURM_ARRAY_TASK_ID]}"
echo "=== Evaluating $EXP_ID  (array $SLURM_ARRAY_TASK_ID / $((N - 1))) ==="

METRICS_JSON="output/${EXP_ID}/test-output_metrics.json"
if [ -f "$METRICS_JSON" ] && [ "$FORCE" != "1" ]; then
    echo "Already evaluated: $METRICS_JSON  (set FORCE=1 to redo)"
    cat "$METRICS_JSON"
    exit 0
fi

# Verify there's something to evaluate (final EMA OR at least one EMA buffer)
if [ ! -f "output/${EXP_ID}/${EXP_ID}_ema_final.pth" ] && \
   [ -z "$(ls -A output/${EXP_ID}/ema_ckpts 2>/dev/null)" ]; then
    echo "Skipping ${EXP_ID}: no EMA buffers (training didn't reach ema.checkpoint_every iters)"
    exit 0
fi

# --- 6. Run eval ---
OMP_NUM_THREADS=2 torchrun --standalone --nproc_per_node=1 eval_run.py \
    exp_id="$EXP_ID" \
    model="$MODEL" \
    duration_s="$DURATION" \
    batch_size="$BATCH_SIZE" \
    ++eval_extract_batch_size="$EXTRACT_BS" \
    num_workers="$NUM_WORKERS" \
    compile="$COMPILE"

echo "Done. Metrics for ${EXP_ID}:"
cat "$METRICS_JSON"