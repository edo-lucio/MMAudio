#!/bin/bash
#SBATCH --job-name=mma_eval_all
#SBATCH --output=logs/eval_all_%A_%a.out
#SBATCH --error=logs/eval_all_%A_%a.err
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=64G
#SBATCH --time=06:00:00
#SBATCH --partition=acltr
#SBATCH --gres=gpu:1
#SBATCH --array=0-%A_IDX%
#SBATCH --mail-user=edlu@itu.dk
#SBATCH --mail-type=FAIL,ARRAY_TASKS

# Array eval: one task per finished run under output/.
# Before sbatch, set the array range to match the number of runs:
#   N=$(ls -d output/gw_* | wc -l); sbatch --array=0-$((N-1)) jobs/eval_all.job

PROJECT_DIR="$HOME/MMA/MMAudio"
ENV_PATH="/home/edlu/miniconda3-25-5-1-1/envs/gwot"
source "$PROJECT_DIR/jobs/_header.sh"

MODEL="${MODEL:-small_16k}"
DURATION="${DURATION:-8}"
DATASET="${DATASET:-vggsound}"
NUM_WORKERS="${NUM_WORKERS:-4}"

# Discover run dirs (skip ones without an ema_final checkpoint)
mapfile -t RUNS < <(ls -1d output/gw_* 2>/dev/null | xargs -n1 basename)
N=${#RUNS[@]}
if [ "$N" -eq 0 ]; then
    echo "No runs in output/gw_*"; exit 2
fi
if [ "$SLURM_ARRAY_TASK_ID" -ge "$N" ]; then
    echo "Array index $SLURM_ARRAY_TASK_ID >= $N runs"; exit 0
fi

EXP_ID="${RUNS[$SLURM_ARRAY_TASK_ID]}"
WEIGHTS="output/${EXP_ID}/${EXP_ID}_ema_final.pth"

echo "Evaluating $EXP_ID (array $SLURM_ARRAY_TASK_ID / $N)"

if [ ! -f "$WEIGHTS" ]; then
    echo "Missing $WEIGHTS — skipping"; exit 0
fi

mkdir -p logs "output/${EXP_ID}/eval"

torchrun --standalone --nproc_per_node=1 batch_eval.py \
    duration_s="$DURATION" \
    dataset="$DATASET" \
    model="$MODEL" \
    num_workers="$NUM_WORKERS" \
    exp_id="$EXP_ID" \
    weights="$WEIGHTS"
