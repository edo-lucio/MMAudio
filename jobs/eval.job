#!/bin/bash
#SBATCH --job-name=mma_eval
#SBATCH --output=logs/eval_%A_%a.out
#SBATCH --error=logs/eval_%A_%a.err
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=64G
#SBATCH --time=06:00:00
#SBATCH --partition=acltr
#SBATCH --gres=gpu:1
#SBATCH --mail-user=edlu@itu.dk
#SBATCH --mail-type=FAIL

# Batch evaluation on VGGSound test set.
#
# Usage:
#   sbatch --export=ALL,EXP_ID=gw_baseline                 jobs/eval.job
#   sbatch --export=ALL,EXP_ID=gw_var_projected,EMA=true   jobs/eval.job
#
# Generates audio for the test set and computes FD_PaSST / IS / IB-score
# / DeSync via av-benchmark. Requires ../data/eval-cache/vggsound-test to
# be present (download from huggingface.co/datasets/hkchengrex/MMAudio-precomputed-results).

PROJECT_DIR="$HOME/MMA/MMAudio"
ENV_PATH="/home/edlu/miniconda3-25-5-1-1/envs/gwot"
source "$PROJECT_DIR/jobs/_header.sh"

: "${EXP_ID:?set EXP_ID=<run_id> via --export=ALL,EXP_ID=...}"
MODEL="${MODEL:-small_16k}"
DURATION="${DURATION:-8}"
DATASET="${DATASET:-vggsound}"
NUM_WORKERS="${NUM_WORKERS:-4}"
GPUS="${GPUS:-1}"
EMA="${EMA:-true}"

# EMA=true  -> use <exp_id>_ema_final.pth
# EMA=false -> use <exp_id>_last.pth (raw weights)
if [ "$EMA" = "true" ]; then
    WEIGHTS="output/${EXP_ID}/${EXP_ID}_ema_final.pth"
else
    WEIGHTS="output/${EXP_ID}/${EXP_ID}_last.pth"
fi

if [ ! -f "$WEIGHTS" ]; then
    echo "Checkpoint not found: $WEIGHTS"
    echo "If training is done, run EMA synthesis first (see Runner docs)."
    exit 2
fi

mkdir -p logs "output/${EXP_ID}/eval"

torchrun --standalone --nproc_per_node="$GPUS" batch_eval.py \
    duration_s="$DURATION" \
    dataset="$DATASET" \
    model="$MODEL" \
    num_workers="$NUM_WORKERS" \
    exp_id="$EXP_ID" \
    weights="$WEIGHTS"
