#!/bin/bash
#SBATCH --job-name=mma_eval
#SBATCH --output=logs/eval_%j.out
#SBATCH --error=logs/eval_%j.err
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=32G
#SBATCH --time=12:00:00
#SBATCH --partition=acltr
#SBATCH --gres=gpu:1
#SBATCH --mail-user=edlu@itu.dk
#SBATCH --mail-type=FAIL

# Post-training evaluation on the VGGSound test set.
#
# Pipeline:
#   1. Synthesize <exp_id>_ema_final.pth from EMA buffers if not on disk.
#   2. Generate audio for the full test set with sample().
#   3. Run av_bench.extract + evaluate to compute FAD-PaSST / IS / CLAP-FAD /
#      IB-score / DeSync.
#   4. Save metrics to output/<exp_id>/test-output_metrics.json.
#
# Submit:
#   sbatch --export=ALL,EXP_ID=gw_baseline                    jobs/eval.job
#   sbatch --export=ALL,EXP_ID=gw_var_global,BATCH_SIZE=64    jobs/eval.job
#
# Required: ../data/eval-cache/vggsound-test (GT feature cache, download from
# huggingface.co/datasets/hkchengrex/MMAudio-precomputed-results).
#
# Auto-skip: if test-output_metrics.json already exists, the run is skipped
# unless FORCE=1 is set.

set -e
set -x

# --- 1. Environment & Path Definitions ---
PROJECT_DIR="$HOME/MMA/MMAudio"
ENV_PATH="/home/edlu/miniconda3-25-5-1-1/envs/gwot"
CONDA_BIN="/opt/itu/easybuild/software/Miniconda3/25.5.1-1/bin/conda"

# --- 2. Load System Modules ---
module load CUDA/12.1.1
module load NCCL/2.18.3-GCCcore-12.3.0-CUDA-12.1.1
module load Miniconda3/25.5.1-1
source /opt/itu/easybuild/software/Miniconda3/25.5.1-1/etc/profile.d/conda.sh
conda activate "$ENV_PATH"
cd "$PROJECT_DIR"

# --- 3. Avoid `import torch` hang on shared FS ---
export TORCH_DEVICE_BACKEND_AUTOLOAD=0
echo "Pre-warming torch import cache..."
time python -c "import torch; print('torch', torch.__version__)"
echo "Cache warm."

mkdir -p logs

# --- 4. Required inputs ---
: "${EXP_ID:?set EXP_ID via --export=ALL,EXP_ID=<run_id>}"

MODEL="${MODEL:-small_16k}"
DURATION="${DURATION:-8.0}"
BATCH_SIZE="${BATCH_SIZE:-32}"
NUM_WORKERS="${NUM_WORKERS:-4}"
FORCE="${FORCE:-0}"
COMPILE="${COMPILE:-False}"   # default False because sm_75 GPUs can't JIT bf16 kernels

# --- 5. Skip if already evaluated ---
METRICS_JSON="output/${EXP_ID}/test-output_metrics.json"
if [ -f "$METRICS_JSON" ] && [ "$FORCE" != "1" ]; then
    echo "Already evaluated: $METRICS_JSON"
    echo "Re-run with FORCE=1 to overwrite."
    cat "$METRICS_JSON"
    exit 0
fi

# --- 6. Verify the run dir + at least one EMA buffer exist ---
if [ ! -d "output/${EXP_ID}" ]; then
    echo "ERROR: output/${EXP_ID}/ doesn't exist — wrong EXP_ID?"
    exit 2
fi
if [ ! -f "output/${EXP_ID}/${EXP_ID}_ema_final.pth" ] && \
   [ -z "$(ls -A output/${EXP_ID}/ema_ckpts 2>/dev/null)" ]; then
    echo "ERROR: neither <exp_id>_ema_final.pth nor any ema_ckpts/* exist for ${EXP_ID}"
    echo "       Train must reach at least ema.checkpoint_every (5000) iters before eval."
    exit 2
fi

# --- 7. Run ---
OMP_NUM_THREADS=2 torchrun --standalone --nproc_per_node=1 eval_run.py \
    exp_id="$EXP_ID" \
    model="$MODEL" \
    duration_s="$DURATION" \
    batch_size="$BATCH_SIZE" \
    num_workers="$NUM_WORKERS" \
    compile="$COMPILE"

echo "Done. Metrics:"
cat "$METRICS_JSON"
